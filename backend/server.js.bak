import express from 'express';
import cors from 'cors';
import jwt from 'jsonwebtoken';
import bcrypt from 'bcrypt';
import { createServer } from 'http';
import { Server as SocketIO } from 'socket.io';
import cron from 'node-cron';
import path from 'path';
import fs from 'fs';
import { fileURLToPath } from 'url';
import multer from 'multer';
import db from './db.js';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const app = express();
const httpServer = createServer(app);
const io = new SocketIO(httpServer, { cors: { origin: '*' } });

const JWT_SECRET = process.env.JWT_SECRET || 'creonix-secret-2024';
const PORT = process.env.PORT || 3001;

app.use(cors());
app.use(express.json({ limit: '10mb' }));
// Assets (JS/CSS) — долгий кэш (они content-hashed)
app.use('/assets', express.static(path.join(__dirname, 'public', 'assets'), { maxAge: '7d' }));
// index.html — никакого кэша, всегда свежий
app.use(express.static(path.join(__dirname, 'public'), {
  setHeaders(res, filePath) {
    if (filePath.endsWith('index.html')) {
      res.setHeader('Cache-Control', 'no-store, no-cache, must-revalidate');
    }
  }
}));

// Auth middleware
function auth(req, res, next) {
  const token = req.headers.authorization?.split(' ')[1];
  if (!token) return res.status(401).json({ error: 'Unauthorized' });
  try {
    req.user = jwt.verify(token, JWT_SECRET);
    next();
  } catch {
    res.status(401).json({ error: 'Invalid token' });
  }
}

// ── AUTH ─────────────────────────────────────────────
app.post('/api/auth/login', async (req, res) => {
  const { password } = req.body;
  const setting = db.prepare('SELECT value FROM system_settings WHERE key = ?').get('password_hash');

  if (!setting?.value) {
    // First-time setup — set password
    const hash = await bcrypt.hash(password, 10);
    db.prepare('UPDATE system_settings SET value = ? WHERE key = ?').run(hash, 'password_hash');
    const token = jwt.sign({ user: 'admin' }, JWT_SECRET, { expiresIn: '30d' });
    return res.json({ token, firstTime: true });
  }

  const valid = await bcrypt.compare(password, setting.value);
  if (!valid) return res.status(401).json({ error: 'Неверный пароль' });

  const token = jwt.sign({ user: 'admin' }, JWT_SECRET, { expiresIn: '30d' });
  res.json({ token });
});

app.post('/api/auth/change-password', auth, async (req, res) => {
  const { newPassword } = req.body;
  const hash = await bcrypt.hash(newPassword, 10);
  db.prepare('UPDATE system_settings SET value = ? WHERE key = ?').run(hash, 'password_hash');
  res.json({ ok: true });
});

// ── ACCOUNTS ──────────────────────────────────────────
app.get('/api/accounts', auth, (req, res) => {
  const accounts = db.prepare('SELECT * FROM accounts ORDER BY created_at DESC').all();
  res.json(accounts);
});

app.post('/api/accounts', auth, (req, res) => {
  const { phone, proxy_host, proxy_port, proxy_user, proxy_pass, proxy_type, notes } = req.body;
  try {
    const result = db.prepare(`
      INSERT INTO accounts (phone, proxy_host, proxy_port, proxy_user, proxy_pass, proxy_type, notes, status)
      VALUES (?, ?, ?, ?, ?, ?, ?, 'inactive')
    `).run(phone, proxy_host, proxy_port, proxy_user, proxy_pass, proxy_type || 'socks5', notes);
    const account = db.prepare('SELECT * FROM accounts WHERE id = ?').get(result.lastInsertRowid);
    res.json(account);
  } catch (e) {
    res.status(400).json({ error: e.message });
  }
});

// tdata import — must be before :id routes
const tdataDir = path.join(__dirname, 'tdata_uploads');
fs.mkdirSync(tdataDir, { recursive: true });

const tdataUpload = multer({
  storage: multer.diskStorage({
    destination: (req, file, cb) => {
      if (!req._uploadDir) {
        req._uploadDir = path.join(tdataDir, `session_${Date.now()}`);
        fs.mkdirSync(req._uploadDir, { recursive: true });
      }
      // Preserve directory structure from webkitRelativePath
      const relDir = path.dirname(file.originalname);
      const destDir = (relDir && relDir !== '.') ? path.join(req._uploadDir, relDir) : req._uploadDir;
      fs.mkdirSync(destDir, { recursive: true });
      cb(null, destDir);
    },
    filename: (req, file, cb) => cb(null, path.basename(file.originalname)),
  }),
  limits: { fileSize: 200 * 1024 * 1024 },
});

app.post('/api/accounts/import-tdata', auth, tdataUpload.array('tdata', 500), async (req, res) => {
  if (!req.files?.length) return res.status(400).json({ error: 'Файлы не загружены' });

  const uploadDir = req._uploadDir;

  // Debug: log received files and directory structure
  console.log('[tdata] files received:', req.files.map(f => f.originalname));
  const { execSync } = require('child_process');
  try { console.log('[tdata] uploadDir tree:', execSync(`find ${uploadDir} -maxdepth 4`).toString()); } catch {}

  // Try to find the tdata subfolder or use uploadDir directly
  let tdataPath = uploadDir;
  const subDirs = fs.readdirSync(uploadDir, { withFileTypes: true });
  const tdataSub = subDirs.find(d => d.isDirectory() && d.name.toLowerCase() === 'tdata');
  if (tdataSub) tdataPath = path.join(uploadDir, tdataSub.name);
  console.log('[tdata] tdataPath:', tdataPath);

  const { execFile } = await import('child_process');
  const { promisify } = await import('util');
  const execFileAsync = promisify(execFile);

  try {
    const scriptPath = path.join(__dirname, 'tdata_convert.py');
    const { stdout, stderr } = await execFileAsync('python3', [scriptPath, tdataPath], {
      timeout: 60000,
    });

    let parsed;
    try { parsed = JSON.parse(stdout.trim()); } catch {
      return res.status(500).json({ error: 'Ошибка парсинга tdata: ' + stdout });
    }

    // Single error object
    if (parsed.error) return res.status(400).json({ error: parsed.error });

    // Array of accounts
    const accounts = [];
    for (const item of parsed) {
      if (item.error) continue; // skip failed accounts
      const result = db.prepare(`
        INSERT INTO accounts (phone, session_string, status, first_name, last_name, username, user_id)
        VALUES (?, ?, 'active', ?, ?, ?, ?)
      `).run(item.phone, item.session_string, item.first_name, item.last_name, item.username, item.user_id);
      accounts.push(db.prepare('SELECT * FROM accounts WHERE id = ?').get(result.lastInsertRowid));
    }

    if (!accounts.length) {
      const errors = parsed.filter(i => i.error).map(i => i.error).join('; ');
      return res.status(400).json({ error: 'Не удалось добавить аккаунты. ' + errors });
    }

    // Cleanup uploaded files
    fs.rmSync(uploadDir, { recursive: true, force: true });

    res.json(accounts);
  } catch (e) {
    res.status(500).json({ error: 'Ошибка конвертации tdata: ' + e.message });
  }
});

// ── ZIP IMPORT ────────────────────────────────────────
const zipUpload = multer({
  storage: multer.diskStorage({
    destination: (req, file, cb) => {
      const dir = path.join(tdataDir, `zip_${Date.now()}`);
      fs.mkdirSync(dir, { recursive: true });
      req._zipUploadDir = dir;
      cb(null, dir);
    },
    filename: (req, file, cb) => cb(null, file.originalname),
  }),
  limits: { fileSize: 500 * 1024 * 1024 },
});

app.post('/api/accounts/import-zip', auth, zipUpload.single('zipfile'), async (req, res) => {
  if (!req.file) return res.status(400).json({ error: 'ZIP файл не загружен' });

  const uploadDir = req._zipUploadDir;
  const zipPath = path.join(uploadDir, req.file.originalname);

  try {
    const AdmZip = (await import('adm-zip')).default;
    const zip = new AdmZip(zipPath);
    const extractDir = path.join(uploadDir, 'extracted');
    fs.mkdirSync(extractDir, { recursive: true });
    zip.extractAllTo(extractDir, true);

    // Find tdata subdirectories inside extracted content
    function findTdataDirs(dir) {
      const results = [];
      try {
        const entries = fs.readdirSync(dir, { withFileTypes: true });
        for (const entry of entries) {
          if (entry.isDirectory()) {
            const full = path.join(dir, entry.name);
            // Check if this looks like a tdata folder (has key or D877F783D5D3EF8C file)
            const sub = fs.readdirSync(full, { withFileTypes: true });
            const isTdata = sub.some(f => f.name === 'key_datas' || f.name === 'D877F783D5D3EF8C');
            if (isTdata) {
              results.push(full);
            } else {
              // Recurse one level deeper
              results.push(...findTdataDirs(full));
            }
          }
        }
      } catch {}
      return results;
    }

    const tdataDirs = findTdataDirs(extractDir);
    if (!tdataDirs.length) {
      // Try treating extractDir itself as tdata
      tdataDirs.push(extractDir);
    }

    const { execFile } = await import('child_process');
    const { promisify } = await import('util');
    const execFileAsync = promisify(execFile);
    const scriptPath = path.join(__dirname, 'tdata_convert.py');
    const { TelegramClient } = await import('telegram');
    const { StringSession } = await import('telegram/sessions/index.js');
    const settings = db.prepare('SELECT key, value FROM system_settings').all();
    const sMap = Object.fromEntries(settings.map(s => [s.key, s.value]));

    const added = [];
    const failed = [];
    const skipped = [];

    for (const tdataPath of tdataDirs) {
      try {
        const { stdout } = await execFileAsync('python3', [scriptPath, tdataPath], { timeout: 60000 });
        let parsed;
        try { parsed = JSON.parse(stdout.trim()); } catch { failed.push({ path: tdataPath, error: 'parse error' }); continue; }

        if (!Array.isArray(parsed)) parsed = [parsed];

        for (const item of parsed) {
          if (item.error) { failed.push({ error: item.error }); continue; }

          // Check if already exists
          const existing = db.prepare('SELECT id FROM accounts WHERE phone = ?').get(item.phone);
          if (existing) { skipped.push({ phone: item.phone, reason: 'already exists' }); continue; }

          // Validate session by connecting
          let status = 'active';
          let firstName = item.first_name;
          let lastName = item.last_name;
          let username = item.username;
          let userId = item.user_id;

          try {
            const client = new TelegramClient(
              new StringSession(item.session_string),
              parseInt(sMap.tg_api_id || '2040'),
              sMap.tg_api_hash || 'b18441a1ff607e10a989891a5462e627',
              { connectionRetries: 2, timeout: 15 }
            );
            await client.connect();
            const me = await client.getMe();
            firstName = me.firstName || firstName;
            lastName = me.lastName || lastName;
            username = me.username || username;
            userId = me.id?.toString() || userId;

            // Check spamblock by trying to access a public channel
            try {
              await client.getEntity('@telegram');
            } catch (e) {
              if (e.message?.includes('SPAM') || e.message?.includes('banned')) {
                status = 'spamblock';
              }
            }
            await client.disconnect();
          } catch (e) {
            if (e.message?.includes('AUTH_KEY_UNREGISTERED') || e.message?.includes('UNAUTHORIZED')) {
              status = 'unauthorized';
            } else if (e.message?.includes('USER_DEACTIVATED') || e.message?.includes('banned')) {
              status = 'banned';
            } else {
              status = 'inactive';
            }
          }

          const result = db.prepare(`
            INSERT OR IGNORE INTO accounts (phone, session_string, status, first_name, last_name, username, user_id)
            VALUES (?, ?, ?, ?, ?, ?, ?)
          `).run(item.phone, item.session_string, status, firstName, lastName, username, userId);

          if (result.changes > 0) {
            added.push(db.prepare('SELECT * FROM accounts WHERE id = ?').get(result.lastInsertRowid));
          }
        }
      } catch (e) {
        failed.push({ path: tdataPath, error: e.message });
      }
    }

    // Cleanup
    fs.rmSync(uploadDir, { recursive: true, force: true });

    res.json({ added, failed, skipped, summary: { added: added.length, failed: failed.length, skipped: skipped.length } });
  } catch (e) {
    try { fs.rmSync(uploadDir, { recursive: true, force: true }); } catch {}
    res.status(500).json({ error: 'Ошибка обработки ZIP: ' + e.message });
  }
});

// ── JSON / SESSION IMPORT ─────────────────────────────
const sessionUpload = multer({
  storage: multer.diskStorage({
    destination: (req, file, cb) => {
      if (!req._sessionUploadDir) {
        req._sessionUploadDir = path.join(tdataDir, `sess_${Date.now()}`);
        fs.mkdirSync(req._sessionUploadDir, { recursive: true });
      }
      cb(null, req._sessionUploadDir);
    },
    filename: (req, file, cb) => cb(null, file.originalname),
  }),
  limits: { fileSize: 50 * 1024 * 1024 },
  fileFilter: (req, file, cb) => {
    const ok = file.originalname.endsWith('.session') || file.originalname.endsWith('.json');
    cb(null, ok);
  },
});

app.post('/api/accounts/import-session', auth, sessionUpload.array('files', 200), async (req, res) => {
  if (!req.files?.length) return res.status(400).json({ error: 'Файлы не загружены' });

  const uploadDir = req._sessionUploadDir;
  const { execFile } = await import('child_process');
  const { promisify } = await import('util');
  const execFileAsync = promisify(execFile);
  const scriptPath = path.join(__dirname, 'session_convert.py');
  const { TelegramClient } = await import('telegram');
  const { StringSession } = await import('telegram/sessions/index.js');
  const settings = db.prepare('SELECT key, value FROM system_settings').all();
  const sMap = Object.fromEntries(settings.map(s => [s.key, s.value]));

  const added = [];
  const failed = [];
  const skipped = [];

  try {
    const { stdout } = await execFileAsync('python3', [scriptPath, uploadDir], { timeout: 60000 });
    let parsed;
    try { parsed = JSON.parse(stdout.trim()); } catch {
      return res.status(500).json({ error: 'Ошибка парсинга: ' + stdout });
    }
    if (!Array.isArray(parsed)) parsed = [parsed];

    for (const item of parsed) {
      if (item.error) { failed.push({ error: item.error }); continue; }

      if (!item.session_string) { failed.push({ error: 'Нет session_string' }); continue; }

      // Check duplicate by session_string or phone
      if (item.phone) {
        const existing = db.prepare('SELECT id FROM accounts WHERE phone = ?').get(item.phone);
        if (existing) { skipped.push({ phone: item.phone }); continue; }
      }

      let status = 'inactive';
      let firstName = item.first_name || '';
      let lastName = item.last_name || '';
      let username = item.username || '';
      let userId = item.user_id || '';
      let phone = item.phone || '';

      // Try to validate & fetch profile
      try {
        const client = new TelegramClient(
          new StringSession(item.session_string),
          parseInt(sMap.tg_api_id || '2040'),
          sMap.tg_api_hash || 'b18441a1ff607e10a989891a5462e627',
          { connectionRetries: 2, timeout: 15 }
        );
        await client.connect();
        const me = await client.getMe();
        firstName = me.firstName || firstName;
        lastName = me.lastName || lastName;
        username = me.username || username;
        userId = me.id?.toString() || userId;
        phone = me.phone ? '+' + me.phone : phone;
        status = 'active';
        try {
          await client.getEntity('@telegram');
        } catch (e) {
          if (e.message?.includes('SPAM') || e.message?.includes('banned')) status = 'spamblock';
        }
        await client.disconnect();
      } catch (e) {
        if (e.message?.includes('AUTH_KEY_UNREGISTERED') || e.message?.includes('UNAUTHORIZED')) {
          status = 'unauthorized';
        } else if (e.message?.includes('USER_DEACTIVATED') || e.message?.includes('banned')) {
          status = 'banned';
        } else {
          status = 'inactive';
        }
      }

      if (!phone) { failed.push({ error: 'Не удалось определить телефон из сессии' }); continue; }

      const result = db.prepare(`
        INSERT OR IGNORE INTO accounts (phone, session_string, status, first_name, last_name, username, user_id)
        VALUES (?, ?, ?, ?, ?, ?, ?)
      `).run(phone, item.session_string, status, firstName, lastName, username, userId);

      if (result.changes > 0) {
        added.push(db.prepare('SELECT * FROM accounts WHERE id = ?').get(result.lastInsertRowid));
      } else {
        skipped.push({ phone });
      }
    }
  } catch (e) {
    try { fs.rmSync(uploadDir, { recursive: true, force: true }); } catch {}
    return res.status(500).json({ error: 'Ошибка обработки: ' + e.message });
  }

  try { fs.rmSync(uploadDir, { recursive: true, force: true }); } catch {}
  res.json({ added, failed, skipped, summary: { added: added.length, failed: failed.length, skipped: skipped.length } });
});

app.put('/api/accounts/:id', auth, (req, res) => {
  const { proxy_host, proxy_port, proxy_user, proxy_pass, proxy_type, notes } = req.body;
  db.prepare(`
    UPDATE accounts SET proxy_host=?, proxy_port=?, proxy_user=?, proxy_pass=?, proxy_type=?, notes=?
    WHERE id=?
  `).run(proxy_host || null, proxy_port || null, proxy_user || null, proxy_pass || null,
    proxy_type || 'socks5', notes || null, req.params.id);
  const account = db.prepare('SELECT * FROM accounts WHERE id = ?').get(req.params.id);
  res.json(account);
});

