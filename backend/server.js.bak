app.put('/api/neuro-comment/:id/toggle', auth, (req, res) => {
  const campaign = db.prepare('SELECT * FROM neuro_comment_campaigns WHERE id=?').get(req.params.id);
  const newStatus = campaign.status === 'running' ? 'paused' : 'running';
  // При новом запуске — сбросить старые логи и счётчик комментариев за сегодня
  if (newStatus === 'running') {
    db.prepare('DELETE FROM neuro_comment_logs WHERE campaign_id=?').run(req.params.id);
    db.prepare('UPDATE neuro_comment_campaigns SET comments_today=0 WHERE id=?').run(req.params.id);
  }
  db.prepare('UPDATE neuro_comment_campaigns SET status=? WHERE id=?').run(newStatus, req.params.id);
  res.json({ status: newStatus });
});

