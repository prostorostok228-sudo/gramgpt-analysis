app.delete('/api/accounts/:id', auth, (req, res) => {
  db.prepare('DELETE FROM accounts WHERE id = ?').run(req.params.id);
  res.json({ ok: true });
});

// TG Auth flow
const pendingAuth = new Map();

app.post('/api/accounts/:id/send-code', auth, async (req, res) => {
  try {
    const account = db.prepare('SELECT * FROM accounts WHERE id = ?').get(req.params.id);
    if (!account) return res.status(404).json({ error: 'Account not found' });

    const { TelegramClient } = await import('telegram');
    const { StringSession } = await import('telegram/sessions/index.js');

    const settings = db.prepare('SELECT key, value FROM system_settings').all();
    const sMap = Object.fromEntries(settings.map(s => [s.key, s.value]));

    const apiId = parseInt(sMap.tg_api_id || '2040');
    const apiHash = sMap.tg_api_hash || 'b18441a1ff607e10a989891a5462e627';

    const client = new TelegramClient(new StringSession(''), apiId, apiHash, {
      connectionRetries: 3,
      proxy: buildProxy(account),
    });

    await client.connect();

    let phoneCodeHash;
    try {
      const result = await client.sendCode({ apiId, apiHash }, account.phone);
      phoneCodeHash = result.phoneCodeHash;
    } catch (e) {
      return res.status(400).json({ error: e.message });
    }

    pendingAuth.set(account.id, { client, phoneCodeHash, phone: account.phone });
    res.json({ ok: true, phoneCodeHash });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

app.post('/api/accounts/:id/verify-code', auth, async (req, res) => {
  const { code, password } = req.body;
  const pending = pendingAuth.get(parseInt(req.params.id));
  if (!pending) return res.status(400).json({ error: 'No pending auth' });

  try {
    const { TelegramClient } = await import('telegram');
    const { client, phoneCodeHash, phone } = pending;

    try {
      await client.invoke(new (await import('telegram/tl/functions/auth/index.js')).SignIn({
        phoneNumber: phone,
        phoneCodeHash,
        phoneCode: code,
      }));
    } catch (e) {
      if (e.message?.includes('SESSION_PASSWORD_NEEDED')) {
        if (!password) return res.json({ needPassword: true });
        const { checkPassword } = await import('telegram/utils.js');
        const passwordSrpResult = await client.invoke(
          new (await import('telegram/tl/functions/account/index.js')).GetPassword()
        );
        await client.invoke(await checkPassword(passwordSrpResult, password));
      } else throw e;
    }

    const me = await client.getMe();
    const sessionString = client.session.save();

    db.prepare(`
      UPDATE accounts SET session_string=?, status='active', first_name=?, last_name=?, username=?, user_id=?
      WHERE id=?
    `).run(sessionString, me.firstName, me.lastName, me.username, me.id?.toString(), req.params.id);

    pendingAuth.delete(parseInt(req.params.id));
    await client.disconnect();

    const account = db.prepare('SELECT * FROM accounts WHERE id = ?').get(req.params.id);
    res.json(account);
  } catch (e) {
    res.status(400).json({ error: e.message });
  }
});

app.post('/api/accounts/:id/check', auth, async (req, res) => {
  const account = db.prepare('SELECT * FROM accounts WHERE id = ?').get(req.params.id);
  if (!account?.session_string) return res.json({ status: 'inactive' });

  try {
    const { TelegramClient } = await import('telegram');
    const { StringSession } = await import('telegram/sessions/index.js');
    const settings = db.prepare('SELECT key, value FROM system_settings').all();
    const sMap = Object.fromEntries(settings.map(s => [s.key, s.value]));

    const client = new TelegramClient(
      new StringSession(account.session_string),
      parseInt(sMap.tg_api_id || '2040'),
      sMap.tg_api_hash || 'b18441a1ff607e10a989891a5462e627',
      { connectionRetries: 2, proxy: buildProxy(account) }
    );
    await client.connect();
    const me = await client.getMe();
    await client.disconnect();

    db.prepare(`UPDATE accounts SET status='active', first_name=?, last_name=?, username=? WHERE id=?`)
      .run(me.firstName, me.lastName, me.username, req.params.id);

    res.json({ status: 'active', user: me });
  } catch (e) {
    const status = e.message?.includes('AUTH_KEY_UNREGISTERED') ? 'unauthorized'
      : e.message?.includes('USER_DEACTIVATED') ? 'banned' : 'error';
    db.prepare('UPDATE accounts SET status=? WHERE id=?').run(status, req.params.id);
    res.json({ status, error: e.message });
  }
});


// ── QR LOGIN ──────────────────────────────────────────
const pendingQr = new Map();

app.post('/api/accounts/qr-start', auth, async (req, res) => {
  try {
    const { TelegramClient } = await import('telegram');
    const { StringSession } = await import('telegram/sessions/index.js');
    const { Api } = await import('telegram');

    const settings = db.prepare('SELECT key, value FROM system_settings').all();
    const sMap = Object.fromEntries(settings.map(s => [s.key, s.value]));

    const apiId = parseInt(sMap.tg_api_id || '2040');
    const apiHash = sMap.tg_api_hash || 'b18441a1ff607e10a989891a5462e627';

    const client = new TelegramClient(new StringSession(''), apiId, apiHash, {
      connectionRetries: 3,
    });
    await client.connect();

    const tokenResult = await client.invoke(new Api.auth.ExportLoginToken({
      apiId, apiHash, exceptIds: [],
    }));

    if (!tokenResult.token) throw new Error('Не удалось получить QR токен');

    const token = Buffer.from(tokenResult.token).toString('base64url');
    const tempId = Date.now().toString(36) + Math.random().toString(36).slice(2);

    pendingQr.set(tempId, { client, apiId, apiHash, expires: Date.now() + 120000 });

    // Auto-cleanup after 2 min
    setTimeout(() => {
      const entry = pendingQr.get(tempId);
      if (entry) { try { entry.client.disconnect(); } catch (_) {} pendingQr.delete(tempId); }
    }, 120000);

    res.json({ tempId, qrUrl: `tg://login?token=${token}`, expiresIn: 30 });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

app.get('/api/accounts/qr-status/:tempId', auth, async (req, res) => {
  const entry = pendingQr.get(req.params.tempId);
  if (!entry) return res.json({ status: 'expired' });
  if (Date.now() > entry.expires) {
    try { entry.client.disconnect(); } catch (_) {}
    pendingQr.delete(req.params.tempId);
    return res.json({ status: 'expired' });
  }

  try {
    const { Api } = await import('telegram');
    const { client, apiId, apiHash } = entry;

    const result = await client.invoke(new Api.auth.ExportLoginToken({
      apiId, apiHash, exceptIds: [],
    }));

    // LoginTokenSuccess — user scanned and authorized
    if (result.className === 'auth.LoginTokenSuccess' || result.authorization) {
      const me = await client.getMe();
      const sessionString = client.session.save();

      const existing = db.prepare('SELECT id FROM accounts WHERE user_id=?').get(me.id?.toString());
      let accountId;
      if (existing) {
        db.prepare(`UPDATE accounts SET session_string=?, status='active', first_name=?, last_name=?, username=?, phone=? WHERE id=?`)
          .run(sessionString, me.firstName, me.lastName, me.username, me.phone || '', existing.id);
        accountId = existing.id;
      } else {
        const ins = db.prepare(`INSERT INTO accounts (phone, session_string, status, first_name, last_name, username, user_id) VALUES (?,?,'active',?,?,?,?)`)
          .run(me.phone || '', sessionString, me.firstName, me.lastName, me.username, me.id?.toString());
        accountId = ins.lastInsertRowid;
      }

      await client.disconnect();
      pendingQr.delete(req.params.tempId);

      const account = db.prepare('SELECT * FROM accounts WHERE id=?').get(accountId);
      return res.json({ status: 'authorized', account });
    }

    // LoginTokenMigrate — need DC migration
    if (result.className === 'auth.LoginTokenMigrate') {
      await client._switchDC(result.dcId);
      const migrated = await client.invoke(new Api.auth.ImportLoginToken({ token: result.token }));
      if (migrated.authorization) {
        const me = await client.getMe();
        const sessionString = client.session.save();
        const ins = db.prepare(`INSERT OR REPLACE INTO accounts (phone, session_string, status, first_name, last_name, username, user_id) VALUES (?,?,'active',?,?,?,?)`)
          .run(me.phone || '', sessionString, me.firstName, me.lastName, me.username, me.id?.toString());
        await client.disconnect();
        pendingQr.delete(req.params.tempId);
        const account = db.prepare('SELECT * FROM accounts WHERE id=?').get(ins.lastInsertRowid);
        return res.json({ status: 'authorized', account });
      }
    }

    // Still pending — return fresh QR token
    const freshToken = Buffer.from(result.token).toString('base64url');
    res.json({ status: 'pending', qrUrl: `tg://login?token=${freshToken}` });
  } catch (e) {
    res.json({ status: 'error', error: e.message });
  }
});

