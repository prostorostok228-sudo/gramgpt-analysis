  const allowed = ['channel_link','channel_name','telegram_notify_bot_token',
                   'telegram_notify_chat_id','claude_api_key','agent_interval_hours',
                   'agent_auto_apply','tg_api_id','tg_api_hash','timezone'];
  const updates = Object.entries(req.body).filter(([k]) => allowed.includes(k));
  const stmt = db.prepare('UPDATE system_settings SET value=? WHERE key=?');
  updates.forEach(([k, v]) => stmt.run(v, k));
  res.json({ ok: true });
});

// ── LOGS ──────────────────────────────────────────────
app.get('/api/logs', auth, (req, res) => {
  const { module, level, limit = 100 } = req.query;
  let query = 'SELECT * FROM system_logs';
  const params = [];
  const conditions = [];
  if (module) { conditions.push('module = ?'); params.push(module); }
  if (level) { conditions.push('level = ?'); params.push(level); }
  if (conditions.length) query += ' WHERE ' + conditions.join(' AND ');
  query += ' ORDER BY created_at DESC LIMIT ?';
  params.push(parseInt(limit));
  res.json(db.prepare(query).all(...params));
});

// ── ASYNC WORKERS ─────────────────────────────────────
async function runParsingTask(task, io) {
  const sources = JSON.parse(task.sources);
  const filters = JSON.parse(task.filters || '{}');
  const account = db.prepare('SELECT * FROM accounts WHERE id = ?').get(task.account_id);

  if (!account?.session_string) throw new Error('No active account');
  if (account.status === 'frozen' && account.flood_wait_until && account.flood_wait_until > new Date().toISOString()) {
    throw new Error(`Аккаунт заморожен до ${account.flood_wait_until}`);
  }

  const { TelegramClient } = await import('telegram');
  const { StringSession } = await import('telegram/sessions/index.js');
  const settings = db.prepare('SELECT key, value FROM system_settings').all();
  const sMap = Object.fromEntries(settings.map(s => [s.key, s.value]));

  const client = new TelegramClient(
    new StringSession(account.session_string),
    parseInt(sMap.tg_api_id || '2040'),
    sMap.tg_api_hash || 'b18441a1ff607e10a989891a5462e627',
    { connectionRetries: 3, proxy: buildProxy(account) }
  );

  await client.connect();
  let total = 0;
  const insertUser = db.prepare(`
    INSERT OR IGNORE INTO parsed_users (task_id, user_id, username, first_name, last_name, is_premium, is_bot, lang_code, source_channel)
    VALUES (?,?,?,?,?,?,?,?,?)
  `);

  for (const source of sources) {
    try {
      const entity = await client.getEntity(source);
      const participants = await client.getParticipants(entity, { limit: filters.members_limit || 1000 });

      for (const p of participants) {
        if (filters.skip_bots && p.bot) continue;
        if (filters.skip_deleted && p.deleted) continue;
        if (filters.only_with_username && !p.username) continue;
        if (filters.only_premium && !p.premium) continue;

        insertUser.run(task.id, p.id?.toString(), p.username, p.firstName, p.lastName,
          p.premium ? 1 : 0, p.bot ? 1 : 0, p.langCode, source);
        total++;
      }

      io.emit('parsing:progress', { id: task.id, source, count: total });
      await new Promise(r => setTimeout(r, 1000));
    } catch (e) {
      if (e.message?.includes('FROZEN_METHOD_INVALID') || e.message?.includes('FROZEN_METHOD')) {
        freezeAccount(db, task.account_id);
        logSystem('warn', 'parsing', `Account ${task.account_id} frozen 24h: ${e.message}`, db);
        break;
      }
      logSystem('error', 'parsing', `Failed to parse ${source}: ${e.message}`, db);
    }
  }

  await client.disconnect();
  db.prepare(`UPDATE parsing_tasks SET status='completed', result_count=?, completed_at=datetime('now') WHERE id=?`)
    .run(total, task.id);
  io.emit('parsing:update', { id: task.id, status: 'completed', count: total });
}

async function runChannelSearchTask(task, io) {
  const account = db.prepare('SELECT * FROM accounts WHERE id = ?').get(task.account_id);
  if (!account?.session_string) throw new Error('No active account');
  if (account.status === 'frozen' && account.flood_wait_until && account.flood_wait_until > new Date().toISOString()) {
    throw new Error(`Аккаунт заморожен до ${account.flood_wait_until}`);
  }

  const { TelegramClient } = await import('telegram');
  const { StringSession } = await import('telegram/sessions/index.js');
  const { Api } = await import('telegram');
  const settings = db.prepare('SELECT key, value FROM system_settings').all();
  const sMap = Object.fromEntries(settings.map(s => [s.key, s.value]));

  const client = new TelegramClient(
    new StringSession(account.session_string),
    parseInt(sMap.tg_api_id || '2040'),
    sMap.tg_api_hash || 'b18441a1ff607e10a989891a5462e627',
    { connectionRetries: 3, proxy: buildProxy(account) }
  );

  await client.connect();

  const insertChannel = db.prepare(`
    INSERT OR IGNORE INTO parsed_channels (search_id, channel_id, title, username, description, members_count)
    VALUES (?,?,?,?,?,?)
  `);

  let total = 0;
  const limit = Math.min(task.result_limit || 100, 200);
  const minMembers = task.min_members || 0;

  function processChat(chat) {
    if (total >= limit) return;
    if (!chat.username || !chat.title) return;
    const memberCount = chat.participantsCount || 0;
    if (memberCount < minMembers) return;
    const ins = insertChannel.run(
      task.id,
      chat.id?.toString(),
      chat.title || '',
      chat.username || '',
      chat.about || '',
      memberCount
    );
    if (ins.changes > 0) {
      total++;
      io.emit('channels:progress', { id: task.id, count: total });
    }
  }

  try {
    // Разбиваем по запятой, ищем по каждому ключевому слову
    const keywords = task.keyword.split(',').map(k => k.trim()).filter(Boolean);

    for (const kw of keywords) {
      if (total >= limit) break;

      // Метод 1: messages.SearchGlobal — основной (contacts.Search заморожен у ряда API ID)
      try {
        const globalResult = await client.invoke(new Api.messages.SearchGlobal({
          q: kw,
          filter: new Api.InputMessagesFilterEmpty(),
          minDate: 0,
          maxDate: 0,
          offsetRate: 0,
          offsetPeer: new Api.InputPeerEmpty(),
          offsetId: 0,
          limit: 100,
        }));
        for (const chat of (globalResult.chats || [])) processChat(chat);
      } catch (e) {
        // если SearchGlobal тоже заморожен — пробуем contacts.Search
        if (e.message?.includes('FROZEN')) {
          try {
            const result = await client.invoke(new Api.contacts.Search({ q: kw, limit: 100 }));
            for (const chat of (result.chats || [])) processChat(chat);
          } catch {}
        }
      }
    }
  } finally {
    await client.disconnect();
  }

  db.prepare(`UPDATE channel_searches SET status='completed', result_count=?, completed_at=datetime('now') WHERE id=?`)
    .run(total, task.id);
  io.emit('channels:update', { id: task.id, status: 'completed', count: total });
}

async function runMassReact(campaign, io) {
  const channels = JSON.parse(campaign.target_channels);
  const accountIds = JSON.parse(campaign.accounts_pool);
  const reactions = JSON.parse(campaign.reactions);

  const settings = db.prepare('SELECT key, value FROM system_settings').all();
  const sMap = Object.fromEntries(settings.map(s => [s.key, s.value]));

  let totalDone = 0;

  for (const accountId of accountIds) {
    const account = db.prepare('SELECT * FROM accounts WHERE id=? AND status="active"').get(accountId);
    if (!account?.session_string) continue;

    try {
      const { TelegramClient } = await import('telegram');
      const { StringSession } = await import('telegram/sessions/index.js');

      const client = new TelegramClient(
        new StringSession(account.session_string),
        parseInt(sMap.tg_api_id || '2040'),
        sMap.tg_api_hash || 'b18441a1ff607e10a989891a5462e627',
        { connectionRetries: 3, proxy: buildProxy(account) }
      );

      await client.connect();

      for (const channel of channels) {
        try {
          const entity = await client.getEntity(channel);
          const messages = await client.getMessages(entity, { limit: campaign.posts_count });

          for (const msg of messages) {
            const reaction = reactions[Math.floor(Math.random() * reactions.length)];
            try {
              await client.invoke(new (await import('telegram/tl/functions/messages/index.js')).SendReaction({
                peer: entity,
                msgId: msg.id,
                reaction: [{ _: 'reactionEmoji', emoticon: reaction }],
              }));

              db.prepare(`INSERT INTO mass_react_logs (campaign_id, account_id, channel, message_id, reaction, status)
                VALUES (?,?,?,?,?,'done')`).run(campaign.id, account.id, channel, msg.id, reaction);
              totalDone++;
              io.emit('massreact:progress', { campaign_id: campaign.id, total: totalDone });

              const delay = campaign.delay_min_seconds * 1000 +
                Math.random() * (campaign.delay_max_seconds - campaign.delay_min_seconds) * 1000;
              await new Promise(r => setTimeout(r, delay));
            } catch (e) {
              db.prepare(`INSERT INTO mass_react_logs (campaign_id, account_id, channel, message_id, reaction, status)
                VALUES (?,?,?,?,?,'error')`).run(campaign.id, account.id, channel, msg.id, reaction);
            }
          }
        } catch (e) {
          logSystem('error', 'mass-react', `Channel ${channel}: ${e.message}`, db);
        }
      }

      await client.disconnect();
    } catch (e) {
      if (e.message?.includes('FROZEN_METHOD_INVALID') || e.message?.includes('FROZEN_METHOD')) {
        freezeAccount(db, accountId);
        logSystem('warn', 'mass-react', `Account ${accountId} frozen 24h: ${e.message}`, db);
      } else {
        logSystem('error', 'mass-react', `Account ${accountId}: ${e.message}`, db);
      }
    }
  }

  db.prepare('UPDATE mass_react_campaigns SET total_reactions=total_reactions+? WHERE id=?')
    .run(totalDone, campaign.id);
}

async function runAIAgent(settings, io) {
  try {
    const Anthropic = (await import('@anthropic-ai/sdk')).default;
    const client = new Anthropic({ apiKey: settings.claude_api_key });

    const accounts = db.prepare('SELECT status, COUNT(*) as cnt FROM accounts GROUP BY status').all();
    const recentComments = db.prepare('SELECT COUNT(*) as cnt FROM neuro_comment_logs WHERE created_at > datetime("now", "-24 hours")').get();
    const recentDMs = db.prepare('SELECT COUNT(*) as cnt FROM neuro_chat_contacts WHERE sent_at > datetime("now", "-24 hours")').get();
    const channelStats = db.prepare('SELECT * FROM channel_stats ORDER BY date DESC LIMIT 7').all();

    const prompt = `Ты AI-агент системы Creonix (инструмент продвижения Telegram каналов).
Проанализируй текущее состояние системы и дай рекомендации.

Данные:
- Аккаунты: ${JSON.stringify(accounts)}
- Комментариев за 24ч: ${recentComments?.cnt || 0}
- ДМ за 24ч: ${recentDMs?.cnt || 0}
- Статистика канала (7 дней): ${JSON.stringify(channelStats)}
- Канал: ${settings.channel_link || 'не указан'}

Дай краткий анализ (2-3 предложения), выяви проблемы (список) и дай рекомендации (список из 3-5 пунктов).
Ответь в JSON: { "summary": "...", "problems": ["..."], "recommendations": ["..."] }`;

    const response = await client.messages.create({
      model: 'claude-haiku-4-5-20251001',
      max_tokens: 1024,
      messages: [{ role: 'user', content: prompt }],
    });

    const text = response.content[0].text;
    let parsed;
    try {
      const jsonMatch = text.match(/\{[\s\S]*\}/);
      parsed = jsonMatch ? JSON.parse(jsonMatch[0]) : { summary: text, problems: [], recommendations: [] };
    } catch {
      parsed = { summary: text, problems: [], recommendations: [] };
    }

    const result = db.prepare(`
      INSERT INTO agent_analyses (summary, problems, recommendations)
      VALUES (?,?,?)
    `).run(parsed.summary, JSON.stringify(parsed.problems), JSON.stringify(parsed.recommendations));

    io.emit('agent:complete', { id: result.lastInsertRowid, ...parsed });
  } catch (e) {
    logSystem('error', 'agent', e.message, db);
    io.emit('agent:error', { error: e.message });
  }
}

function logSystem(level, module, message, db, details = null) {
  db.prepare('INSERT INTO system_logs (level, module, message, details) VALUES (?,?,?,?)')
    .run(level, module, message, details);
}

// Neuro commenting worker (every 5 minutes)
cron.schedule('*/5 * * * *', async () => {
  const campaigns = db.prepare("SELECT * FROM neuro_comment_campaigns WHERE status='running'").all();
  for (const campaign of campaigns) {
    await runNeuroComment(campaign, io).catch(e =>
      logSystem('error', 'neuro-comment', e.message, db)
    );
  }
});

// Auto-unfreeze accounts after 24h freeze expires
cron.schedule('0 * * * *', () => {
  db.prepare("UPDATE accounts SET status='inactive', flood_wait_until=NULL WHERE status='frozen' AND flood_wait_until <= datetime('now')").run();
});

// AI Agent auto-run
cron.schedule('0 */6 * * *', async () => {
  const settings = db.prepare('SELECT key, value FROM system_settings').all();
  const sMap = Object.fromEntries(settings.map(s => [s.key, s.value]));
  if (sMap.agent_auto_apply === '1' && sMap.claude_api_key) {
    await runAIAgent(sMap, io);
  }
});

// Build GramJS proxy config from account object (returns undefined if no proxy set)
function buildProxy(account) {
  if (!account?.proxy_host) return undefined;
  return {
    ip: account.proxy_host,
    port: parseInt(account.proxy_port) || 1080,
    username: account.proxy_user || undefined,
    password: account.proxy_pass || undefined,
    socksType: account.proxy_type === 'socks4' ? 4 : 5,
    timeout: 30,
  };
}

// Freeze account for N hours (e.g. after FROZEN_METHOD_INVALID)
function freezeAccount(db, accountId, hours = 24) {
  db.prepare(`UPDATE accounts SET status='frozen', flood_wait_until=datetime('now','+${hours} hours') WHERE id=?`).run(accountId);
}

// Parse channel identifier — returns { type: 'username'|'invite', value: string }
function parseChannel(ch) {
  ch = (ch || '').trim().replace(/\/+$/, ''); // trim whitespace and trailing slashes
  // tg://resolve?domain=USERNAME
  const tgResolveMatch = ch.match(/tg:\/\/resolve\?domain=([a-zA-Z0-9_]{3,})/i);
  if (tgResolveMatch) return { type: 'username', value: '@' + tgResolveMatch[1] };
  // Private invite links: t.me/+HASH or t.me/joinchat/HASH
  const inviteMatch = ch.match(/(?:https?:\/\/)?t\.me\/(?:\+|joinchat\/)([a-zA-Z0-9_-]+)/);
  if (inviteMatch) return { type: 'invite', value: inviteMatch[1] };
  // Public username links: t.me/username (http/https or plain t.me)
  const pubMatch = ch.match(/(?:https?:\/\/)?t\.me\/([a-zA-Z0-9_]{3,})/);
  if (pubMatch) return { type: 'username', value: '@' + pubMatch[1] };
  // Already @username
  if (ch.startsWith('@')) return { type: 'username', value: ch };
  // Plain username
  if (/^[a-zA-Z0-9_]{3,}$/.test(ch)) return { type: 'username', value: '@' + ch };
  return null;
}

// Join a channel and return its entity. Works for both public and private invite links.
async function joinAndGetEntity(client, Api, ch, onLeaveChannel) {
  const parsed = parseChannel(ch);
  if (!parsed) throw new Error(`Cannot parse channel: ${ch}`);

  if (parsed.type === 'invite') {
    // Private link — import invite
    try {
      const result = await client.invoke(new Api.messages.ImportChatInvite({ hash: parsed.value }));
      const chat = result.chats?.[0];
      if (!chat) throw new Error('No chat in ImportChatInvite result');
      // Use BigInt peer for channels
      return await client.getEntity(new Api.PeerChannel({ channelId: chat.id }));
    } catch (e) {
      if (e.message?.includes('CHANNELS_TOO_MUCH')) {
        await leaveOldestChannel(client, Api, onLeaveChannel);
        return await joinAndGetEntity(client, Api, ch, onLeaveChannel);
      }
      if (e.message?.includes('ALREADY') || e.message?.includes('already')) {
        // Already a member — CheckChatInvite returns ChatInviteAlready with .chat field
        try {
          const inv = await client.invoke(new Api.messages.CheckChatInvite({ hash: parsed.value }));
          const chat = inv.chat ?? inv.chats?.[0];
          if (chat) return await client.getEntity(new Api.PeerChannel({ channelId: chat.id }));
        } catch (_) {}
        // Last resort: resolve by invite link directly
        return await client.getEntity('https://t.me/+' + parsed.value);
      }
      throw e;
    }
  } else {
    // Public username
    const entity = await client.getEntity(parsed.value);
    try {
      await client.invoke(new Api.channels.JoinChannel({ channel: entity }));
    } catch (e) {
      if (e.message?.includes('CHANNELS_TOO_MUCH')) {
        await leaveOldestChannel(client, Api, onLeaveChannel);
        await client.invoke(new Api.channels.JoinChannel({ channel: entity }));
        return entity;
      }
      // Ignore "already a member" — rethrow anything else (FloodWait, banned, etc.)
      if (!e.message?.includes('USER_ALREADY_PARTICIPANT') && !e.message?.includes('already')) {
        throw e;
      }
    }
    return entity;
  }
}

async function leaveOldestChannel(client, Api, onLeaveChannel) {
  const dialogs = await client.getDialogs({ limit: 500 });
  const channels = dialogs.filter(d => d.isChannel && !d.entity?.creator);
  if (!channels.length) throw new Error('CHANNELS_TOO_MUCH: нет каналов для выхода');
  const oldest = channels.sort((a, b) => (a.date || 0) - (b.date || 0))[0];
  const title = oldest.title || oldest.entity?.username || 'неизвестный';
  await client.invoke(new Api.channels.LeaveChannel({ channel: oldest.inputEntity }));
  if (onLeaveChannel) onLeaveChannel(title);
}

async function runNeuroComment(campaign, io) {
  const settings = db.prepare('SELECT key, value FROM system_settings').all();
  const sMap = Object.fromEntries(settings.map(s => [s.key, s.value]));

  // Active hours check using user timezone
  const tz = sMap.timezone || 'UTC';
  const now = new Date();
  const hourInTz = parseInt(now.toLocaleString('en-US', { timeZone: tz, hour: 'numeric', hour12: false }));
  const [startH] = campaign.active_hours_start.split(':').map(Number);
  const [endH] = campaign.active_hours_end.split(':').map(Number);
  if (hourInTz < startH || hourInTz >= endH) return;

  // Log: campaign start time
  db.prepare(`INSERT INTO neuro_comment_logs (campaign_id, account_id, channel, status, error_text) VALUES (?,?,?,?,?)`)
    .run(campaign.id, null, '', 'connect', '▶ Кампания запущена: ' + new Date().toLocaleString('ru-RU', { timeZone: tz, timeStyle: 'medium', dateStyle: 'short' }));

  const channels = JSON.parse(campaign.target_channels).filter(Boolean);
  const accountIds = JSON.parse(campaign.accounts_pool);

  // Import GramJS upfront — needed for subscription even without API key
  const { TelegramClient } = await import('telegram');
  const { StringSession } = await import('telegram/sessions/index.js');
  const { Api } = await import('telegram');

  // Lazy-load Anthropic only when API key is present
  let aiClient = null;
  if (sMap.claude_api_key) {
    const Anthropic = (await import('@anthropic-ai/sdk')).default;
    aiClient = new Anthropic({ apiKey: sMap.claude_api_key });
  }

  // Device fingerprints — rotate per account to appear as different devices
  const deviceProfiles = [
    { deviceModel: 'iPhone 14 Pro', systemVersion: 'iOS 17.0', appVersion: '10.5.0', langCode: 'ru' },
    { deviceModel: 'Samsung Galaxy S23', systemVersion: 'Android 13', appVersion: '10.5.0', langCode: 'ru' },
    { deviceModel: 'Pixel 7', systemVersion: 'Android 14', appVersion: '10.5.0', langCode: 'ru' },
    { deviceModel: 'iPhone 13', systemVersion: 'iOS 16.7', appVersion: '10.4.0', langCode: 'ru' },
  ];

  for (const accountId of accountIds) {
    // Skip accounts on flood-wait cooldown
    const account = db.prepare(`SELECT * FROM accounts WHERE id=? AND status='active' AND (flood_wait_until IS NULL OR flood_wait_until < datetime('now'))`).get(accountId);
    if (!account?.session_string) continue;

    // Count only successful comments toward daily limits
    const commentsToday = db.prepare(`
      SELECT COUNT(*) as cnt FROM neuro_comment_logs
      WHERE campaign_id=? AND account_id=? AND status='done' AND created_at > date('now')
    `).get(campaign.id, accountId);
    if (commentsToday.cnt >= campaign.max_per_account_per_day) continue;

    const totalToday = db.prepare(`
      SELECT COUNT(*) as cnt FROM neuro_comment_logs
      WHERE campaign_id=? AND status='done' AND created_at > date('now')
    `).get(campaign.id);
    if (totalToday.cnt >= campaign.max_per_day) break;

    const channelRaw = channels[Math.floor(Math.random() * channels.length)];
    const deviceInfo = deviceProfiles[accountId % deviceProfiles.length];
    let client = null;
    try {
      client = new TelegramClient(
        new StringSession(account.session_string),
        parseInt(sMap.tg_api_id || '2040'),
        sMap.tg_api_hash || 'b18441a1ff607e10a989891a5462e627',
        { connectionRetries: 3, proxy: buildProxy(account), floodSleepThreshold: 0, ...deviceInfo }
      );

      // Log: connecting
      db.prepare(`INSERT INTO neuro_comment_logs (campaign_id, account_id, channel, status, error_text) VALUES (?,?,?,?,?)`)
        .run(campaign.id, accountId, channelRaw, 'connect', `Подключение к Telegram (${account.phone || account.first_name || 'acc#' + accountId})...`);

      await client.connect();

      // Check if session is still authorized
      const isAuth = await client.isUserAuthorized();
      if (!isAuth) {
        db.prepare(`INSERT INTO neuro_comment_logs (campaign_id, account_id, channel, status, error_text) VALUES (?,?,?,?,?)`)
          .run(campaign.id, accountId, channelRaw, 'error', `Сессия аккаунта не авторизована (${account.phone || account.first_name || accountId})`);
        await client.disconnect();
        continue;
      }

      try {
        // Step 1: Subscribe to target channel (always, regardless of API key)
        db.prepare(`INSERT INTO neuro_comment_logs (campaign_id, account_id, channel, status, error_text) VALUES (?,?,?,?,?)`)
          .run(campaign.id, accountId, channelRaw, 'connect', 'Вступление в канал...');

        const entity = await joinAndGetEntity(client, Api, channelRaw, (leftTitle) => {
          db.prepare(`INSERT INTO neuro_comment_logs (campaign_id, account_id, channel, status, error_text) VALUES (?,?,?,?,?)`)
            .run(campaign.id, accountId, channelRaw, 'connect', `CHANNELS_TOO_MUCH: покинул канал "${leftTitle}" для освобождения места, повторяю...`);
        });

        // Log successful join
        db.prepare(`INSERT INTO neuro_comment_logs (campaign_id, account_id, channel, status, error_text) VALUES (?,?,?,?,?)`)
          .run(campaign.id, accountId, channelRaw, 'connect', `✅ Вступил в канал: ${channelRaw}`);

        // Join delay: pause after joining channel before commenting (prevents flood detection)
        const joinDelayMin = campaign.join_delay_min ?? 2;
        const joinDelayMax = campaign.join_delay_max ?? 4;
        if (joinDelayMax > 0) {
          const joinDelaySec = (joinDelayMin + Math.random() * (joinDelayMax - joinDelayMin)) * 60;
          db.prepare(`INSERT INTO neuro_comment_logs (campaign_id, account_id, channel, status, error_text) VALUES (?,?,?,?,?)`)
            .run(campaign.id, accountId, channelRaw, 'connect', `⏱ Задержка после вступления: ${Math.round(joinDelaySec)} сек...`);
          await new Promise(r => setTimeout(r, joinDelaySec * 1000));
        }

        // Step 2: If no API key, log the skip and move on — account is now subscribed
        if (!aiClient) {
          db.prepare(`INSERT INTO neuro_comment_logs (campaign_id, account_id, channel, status, error_text) VALUES (?,?,?,?,?)`)
            .run(campaign.id, accountId, channelRaw, 'skip', 'Claude API key не задан — подписка выполнена, комментарий пропущен');
          await client.disconnect();
          continue;
        }

        // Step 3: Check if channel has a linked discussion group (required for comments)
        const fullInfo = await client.invoke(new Api.channels.GetFullChannel({ channel: entity }));
        const linkedChatId = fullInfo.fullChat.linkedChatId;
        if (!linkedChatId) {
          db.prepare(`INSERT INTO neuro_comment_logs (campaign_id, account_id, channel, status, error_text) VALUES (?,?,?,?,?)`)
            .run(campaign.id, accountId, channelRaw, 'skip', 'Канал не поддерживает комментарии (нет связанной группы обсуждений)');
          await client.disconnect();
          continue;
        }

        const messages = await client.getMessages(entity, { limit: 10 });
        const recent = messages.filter(m => {
          const ageH = (Date.now() / 1000 - m.date) / 3600;
          return ageH <= campaign.max_post_age_hours && (m.text?.length || 0) >= campaign.min_post_length;
        });

        if (!recent.length) {
          db.prepare(`INSERT INTO neuro_comment_logs (campaign_id, account_id, channel, status, error_text) VALUES (?,?,?,?,?)`)
            .run(campaign.id, accountId, channelRaw, 'skip', 'Нет подходящих постов (слишком старые или короткие)');
          await client.disconnect();
          continue;
        }

        // comment_probability: skip commenting with (1 - probability) chance (like gramgpt)
        const commentProb = campaign.comment_probability != null ? campaign.comment_probability : 1.0;
        if (Math.random() > commentProb) {
          db.prepare(`INSERT INTO neuro_comment_logs (campaign_id, account_id, channel, status, error_text) VALUES (?,?,?,?,?)`)
            .run(campaign.id, accountId, channelRaw, 'skip', `Пропущено по вероятности (${Math.round(commentProb * 100)}%)`);
          await client.disconnect();
          continue;
        }

        const post = recent[Math.floor(Math.random() * recent.length)];

        const aiModel = campaign.ai_model || 'claude-haiku-4-5-20251001';
        const aiResponse = await aiClient.messages.create({
          model: aiModel,
          max_tokens: 300,
          messages: [{
            role: 'user',
            content: `Напиши ${campaign.tone === 'friendly' ? 'дружелюбный' : campaign.tone} комментарий к посту в стиле ${campaign.style}.
${campaign.prompt_context ? 'Контекст: ' + campaign.prompt_context : ''}
Пост: "${post.text.substring(0, 500)}"
${campaign.use_emoji ? `Добавь ${campaign.emoji_count} эмодзи.` : 'Без эмодзи.'}
${campaign.banned_words ? 'Не использовать: ' + campaign.banned_words : ''}
Только комментарий, без пояснений.`
          }]
        });

        const commentText = aiResponse.content[0].text.trim();

        // commentTo sends to the linked discussion group (channel comments)
        await client.sendMessage(entity, { message: commentText, commentTo: post.id });

        db.prepare(`INSERT INTO neuro_comment_logs (campaign_id, account_id, channel, message_id, post_text, comment_text, status)
          VALUES (?,?,?,?,?,?,'done')`).run(campaign.id, accountId, channelRaw, post.id, post.text.substring(0, 200), commentText);

        db.prepare(`UPDATE neuro_comment_campaigns SET total_comments=total_comments+1, last_comment_at=datetime('now') WHERE id=?`)
          .run(campaign.id);

        io.emit('neuro-comment:done', { campaign_id: campaign.id, comment: commentText });
      } catch (e) {
        if (e.message?.includes('FROZEN_METHOD_INVALID') || e.message?.includes('FROZEN')) {
          freezeAccount(db, accountId);
          logSystem('warn', 'neuro-comment', `Account ${accountId} frozen 24h: ${e.message}`, db);
        }
        // Handle FLOOD_WAIT: extract seconds, set cooldown on account, skip
        const floodSeconds = e.seconds || (() => {
          const m = e.message?.match(/FLOOD_WAIT[_\s]+(\d+)/i);
          return m ? parseInt(m[1]) : null;
        })();
        if (floodSeconds) {
          const waitMin = Math.round(floodSeconds / 60);
          db.prepare(`UPDATE accounts SET flood_wait_until=datetime('now','+${floodSeconds} seconds') WHERE id=?`).run(accountId);
          db.prepare(`INSERT INTO neuro_comment_logs (campaign_id, account_id, channel, status, error_text) VALUES (?,?,?,?,?)`)
            .run(campaign.id, accountId, channelRaw, 'error', `⏳ FLOOD_WAIT ${floodSeconds} сек (~${waitMin} мин) — аккаунт на паузе до снятия ограничения`);
          await client.disconnect();
          continue;
        }
        db.prepare(`INSERT INTO neuro_comment_logs (campaign_id, account_id, channel, status, error_text)
          VALUES (?,?,?,?,?)`).run(campaign.id, accountId, channelRaw, 'error', e.message);
      }

      await client.disconnect();
    } catch (e) {
      // Connection-level error (bad session, flood, etc.) — log to campaign logs so user sees it
      logSystem('error', 'neuro-comment', `Account ${accountId}: ${e.message}`, db);
      const outerFloodSec = e.seconds || (() => {
        const m = e.message?.match(/FLOOD_WAIT[_\s]+(\d+)/i);
        return m ? parseInt(m[1]) : null;
      })();
      if (outerFloodSec) {
        db.prepare(`UPDATE accounts SET flood_wait_until=datetime('now','+${outerFloodSec} seconds') WHERE id=?`).run(accountId);
        db.prepare(`INSERT INTO neuro_comment_logs (campaign_id, account_id, channel, status, error_text) VALUES (?,?,?,?,?)`)
          .run(campaign.id, accountId, channelRaw, 'error', `⏳ FLOOD_WAIT ${outerFloodSec} сек (~${Math.round(outerFloodSec/60)} мин) при подключении — аккаунт на паузе`);
      } else {
        db.prepare(`INSERT INTO neuro_comment_logs (campaign_id, account_id, channel, status, error_text) VALUES (?,?,?,?,?)`)
          .run(campaign.id, accountId, channelRaw, 'error', `Ошибка подключения аккаунта: ${e.message}`);
      }
      if (client) { try { await client.disconnect(); } catch (_) {} }
    }

    await new Promise(r => setTimeout(r,
      (campaign.delay_min_minutes + Math.random() * (campaign.delay_max_minutes - campaign.delay_min_minutes)) * 60000
    ));
  }
}

// WebSocket
io.on('connection', socket => {
  console.log('Client connected:', socket.id);
});

// Serve frontend for all non-API routes
app.get('*', (req, res) => {
  res.sendFile(path.join(__dirname, 'public', 'index.html'));
});

httpServer.listen(PORT, () => {
  console.log(`Creonix running on port ${PORT}`);
});
