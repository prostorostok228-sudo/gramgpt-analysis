  res.json({ id: result.lastInsertRowid });
});

app.post('/api/parsing/:id/start', auth, async (req, res) => {
  const task = db.prepare('SELECT * FROM parsing_tasks WHERE id = ?').get(req.params.id);
  if (!task) return res.status(404).json({ error: 'Not found' });

  db.prepare(`UPDATE parsing_tasks SET status=?, started_at=datetime('now') WHERE id=?`).run('running', task.id);
  res.json({ ok: true });

  // Run async
  runParsingTask(task, io).catch(e => {
    db.prepare('UPDATE parsing_tasks SET status=?, error_text=? WHERE id=?').run('failed', e.message, task.id);
    io.emit('parsing:update', { id: task.id, status: 'failed', error: e.message });
  });
});

